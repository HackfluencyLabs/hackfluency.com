---
import { getTranslations } from '../i18n/utils';
import type { Language } from '../i18n/translations';

interface Props {
  locale?: Language;
}
const { locale = 'es' } = Astro.props;
const { t } = getTranslations(locale);
---

<!-- Popup Overlay -->
<div id="hf-popup-overlay" role="dialog" aria-modal="true" aria-labelledby="hf-popup-title">
  <div id="hf-popup-card">

    <!-- Ambient glow -->
    <div id="hf-popup-glow" aria-hidden="true"></div>

    <!-- Close -->
    <button id="hf-popup-close" aria-label={t('popup.close')}>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="1" y1="1" x2="13" y2="13"/><line x1="13" y1="1" x2="1" y2="13"/>
      </svg>
    </button>

    <!-- Consulting icon -->
    <div class="popup-icon" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
        <line x1="12" y1="22.08" x2="12" y2="12"/>
      </svg>
    </div>

    <!-- Badge -->
    <div class="popup-badge">
      <span class="popup-badge-dot"></span>
      {t('popup.badge')}
    </div>

    <h3 id="hf-popup-title" set:html={t('popup.title') + '<span class="popup-title-accent">' + t('popup.titleAccent') + '</span>'}>
    </h3>
    <p id="hf-popup-subtitle">
      {t('popup.subtitle')}
    </p>

    <form id="popup-subscribe-form" novalidate>
      <input
        type="email"
        id="popup-email-input"
        placeholder={t('popup.emailPlaceholder')}
        required
        aria-label={t('popup.emailLabel')}
        autocomplete="email"
      />
      <button type="submit" id="popup-submit-btn">
        <span class="popup-btn-text">{t('popup.submit')}</span>
        <span class="popup-btn-spinner" aria-hidden="true"></span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="popup-btn-arrow">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </form>
    <p id="popup-form-message" class="popup-msg"></p>

    <p class="popup-privacy">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      {t('popup.privacy')}
    </p>
    <button type="button" id="popup-not-now" class="popup-not-now">{t('popup.notNow')}</button>
  </div>
</div>

<style>
  /* ── Overlay ─────────────────────────────────────────────────── */
  #hf-popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  /* ── Card ────────────────────────────────────────────────────── */
  #hf-popup-card {
    position: relative;
    background: var(--gray-900, #1f1f1f);
    border: 1px solid color-mix(in srgb, var(--hf-text) 8%, transparent);
    border-top: 1px solid color-mix(in srgb, var(--hf-accent) 50%, transparent);
    border-radius: 20px;
    padding: 40px 36px 32px;
    max-width: 440px;
    width: 100%;
    overflow: hidden;
    /* Entrance animation — applied via JS class */
  }

  #hf-popup-card.popup-enter {
    animation: popupEnter 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  #hf-popup-card.popup-exit {
    animation: popupExit 0.25s ease-in forwards;
  }

  @keyframes popupEnter {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes popupExit {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateY(16px) scale(0.97);
    }
  }

  #hf-popup-overlay.overlay-enter {
    animation: overlayFadeIn 0.3s ease forwards;
  }

  #hf-popup-overlay.overlay-exit {
    animation: overlayFadeOut 0.3s ease forwards;
  }

  @keyframes overlayFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes overlayFadeOut {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  /* ── Ambient glow ─────────────────────────────────────────────── */
  #hf-popup-glow {
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 360px;
    height: 240px;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--hf-accent) 18%, transparent) 0%, transparent 70%);
    pointer-events: none;
    animation: popupPulse 4s ease-in-out infinite alternate;
  }

  @keyframes popupPulse {
    from { opacity: 0.7; transform: translateX(-50%) scale(1); }
    to   { opacity: 1;   transform: translateX(-50%) scale(1.08); }
  }

  /* ── Close button ─────────────────────────────────────────────── */
  #hf-popup-close {
    position: absolute;
    top: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: color-mix(in srgb, var(--hf-text) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--hf-text) 8%, transparent);
    border-radius: 8px;
    color: var(--gray-500, #6a6a6a);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    z-index: 1;
  }

  #hf-popup-close:hover {
    background: var(--hf-border-subtle);
    border-color: color-mix(in srgb, var(--hf-text) 15%, transparent);
    color: var(--white, #fff);
  }

  /* ── Lock icon ─────────────────────────────────────────────────── */
  .popup-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: var(--hf-accent-dim);
    border: 1px solid color-mix(in srgb, var(--hf-accent) 20%, transparent);
    border-radius: 14px;
    color: var(--primary, #00D26A);
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 0 12px var(--hf-accent-border));
  }

  /* ── Badge ─────────────────────────────────────────────────────── */
  .popup-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--hf-accent-dim);
    border: 1px solid var(--hf-accent-border);
    border-radius: 100px;
    font-size: 0.78rem;
    color: var(--primary, #00D26A);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  .popup-badge-dot {
    width: 7px;
    height: 7px;
    background: var(--primary, #00D26A);
    border-radius: 50%;
    animation: badgePulse 2s infinite;
  }

  @keyframes badgePulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  /* ── Title ──────────────────────────────────────────────────────── */
  #hf-popup-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.65rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--white, #fff);
    margin-bottom: 12px;
    position: relative;
    z-index: 1;
    letter-spacing: -0.02em;
  }

  .popup-title-accent {
    background: var(--gradient-neon);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px color-mix(in srgb, var(--hf-accent) 50%, transparent));
  }

  /* ── Subtitle ──────────────────────────────────────────────────── */
  #hf-popup-subtitle {
    font-size: 0.9rem;
    color: var(--gray-400, #8a8a8a);
    margin-bottom: 24px;
    line-height: 1.65;
    position: relative;
    z-index: 1;
  }

  /* ── Form ───────────────────────────────────────────────────────── */
  #popup-subscribe-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    z-index: 1;
  }

  #popup-email-input {
    width: 100%;
    padding: 14px 18px;
    background: color-mix(in srgb, var(--hf-text) 5%, transparent);
    border: 1px solid var(--hf-border-subtle);
    border-radius: 10px;
    color: var(--white, #fff);
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  #popup-email-input:focus {
    border-color: var(--primary, #00D26A);
    box-shadow: 0 0 0 3px var(--hf-accent-dim);
  }

  #popup-email-input::placeholder {
    color: var(--gray-500, #6a6a6a);
  }

  /* ── Submit button ──────────────────────────────────────────────── */
  #popup-submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 24px;
    background: linear-gradient(135deg, var(--primary, #00D26A) 0%, var(--primary-light, #00FF7F) 100%);
    color: var(--hf-text-on-accent);
    border: none;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    font-family: inherit;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px color-mix(in srgb, var(--hf-accent) 35%, transparent);
  }

  .popup-btn-text,
  .popup-btn-arrow {
    position: relative;
    z-index: 1;
    transition: opacity 0.2s ease;
  }

  .popup-btn-spinner {
    display: none;
    width: 18px;
    height: 18px;
    border: 2px solid color-mix(in srgb, var(--hf-text-on-accent) 35%, transparent);
    border-top-color: var(--hf-text-on-accent);
    border-radius: 50%;
    animation: popupSpin 0.6s linear infinite;
    position: relative;
    z-index: 1;
  }

  #popup-submit-btn.loading .popup-btn-text,
  #popup-submit-btn.loading .popup-btn-arrow {
    display: none;
  }

  #popup-submit-btn.loading .popup-btn-spinner {
    display: block;
  }

  @keyframes popupSpin {
    to { transform: rotate(360deg); }
  }

  /* Shimmer sweep */
  #popup-submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.28), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }

  #popup-submit-btn:hover::before {
    transform: translateX(100%);
  }

  #popup-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 36px color-mix(in srgb, var(--hf-accent) 55%, transparent), 0 0 60px color-mix(in srgb, var(--hf-accent-light) 20%, transparent);
  }

  #popup-submit-btn:active {
    transform: scale(0.98);
  }

  #popup-submit-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
  }

  /* ── Not now button ────────────────────────────────────────────── */
  .popup-not-now {
    display: block;
    margin: 12px auto 0;
    background: none;
    border: none;
    color: var(--gray-600, #4a4a4a);
    font-size: 0.78rem;
    font-family: inherit;
    cursor: pointer;
    padding: 8px 16px;
    transition: color 0.2s ease;
    position: relative;
    z-index: 1;
  }

  .popup-not-now:hover {
    color: var(--gray-400, #8a8a8a);
  }

  /* ── Feedback message ────────────────────────────────────────────── */
  .popup-msg {
    margin-top: 4px;
    font-size: 0.84rem;
    min-height: 1.2em;
    text-align: center;
    transition: color 0.3s ease;
    position: relative;
    z-index: 1;
  }

  .popup-msg.success { color: var(--primary, #00D26A); }
  .popup-msg.error   { color: #ff453a; }
  .popup-msg.warning { color: #ffd60a; }
  .popup-msg.info    { color: var(--gray-400, #8a8a8a); }

  /* ── Privacy line ─────────────────────────────────────────────────── */
  .popup-privacy {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 16px;
    color: var(--gray-600, #4a4a4a);
    font-size: 0.78rem;
    position: relative;
    z-index: 1;
  }

  .popup-privacy svg {
    flex-shrink: 0;
    color: var(--gray-600, #4a4a4a);
  }

  /* ── Mobile ───────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    #hf-popup-card {
      padding: 32px 24px 28px;
    }

    #hf-popup-title {
      font-size: 1.4rem;
    }
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    #hf-popup-card.popup-enter,
    #hf-popup-card.popup-exit,
    #hf-popup-overlay.overlay-enter,
    #hf-popup-overlay.overlay-exit {
      animation: none;
    }
    #hf-popup-glow {
      animation: none;
    }
    .popup-badge-dot {
      animation: none;
    }
  }
</style>

<script>
  import { subscribeEmail } from '../lib/subscription';

  const popupLocale = location.pathname.startsWith('/en') ? 'en' : 'es';

  // ── Translations ──────────────────────────────────────────────
  const popupT: Record<string, string> = {
    es: JSON.stringify({
      emailRequired: 'El email es obligatorio',
      emailTooLong: 'Email demasiado largo',
      emailInvalid: 'Formato de email inválido',
      validEmail: 'Email válido',
      sending: 'Enviando...',
      success: '¡Suscrito exitosamente! ✓',
      alreadySubscribed: 'Ya estás suscrito.',
      error: 'Error. Intenta de nuevo.',
      networkError: 'Error de red. Verifica tu conexión.',
      remindLater: 'Te recordaremos más tarde',
    }),
    en: JSON.stringify({
      emailRequired: 'Email is required',
      emailTooLong: 'Email too long',
      emailInvalid: 'Invalid email format',
      validEmail: 'Valid email',
      sending: 'Sending...',
      success: 'Successfully subscribed! ✓',
      alreadySubscribed: 'Already subscribed.',
      error: 'Error. Please try again.',
      networkError: 'Network error. Check connection.',
      remindLater: "We'll remind you later",
    }),
  };
  const msgs = JSON.parse(popupT[popupLocale] || popupT.es);

  // ── Cookie helpers ────────────────────────────────────────────
  function setCookie(name: string, value: string, days: number) {
    const d = new Date();
    d.setDate(d.getDate() + days);
    document.cookie = `${name}=${value}; path=/; expires=${d.toUTCString()}; SameSite=Lax`;
  }
  function getCookie(name: string): string {
    return document.cookie.split('; ').reduce((acc, c) => {
      const [k, v] = c.split('=');
      return k === name ? v : acc;
    }, '');
  }

  // ── Suppression checks ────────────────────────────────────────
  const SUPPRESS_COOKIE = 'hf_popup_suppress';
  const DISMISS_COOKIE  = 'hf_popup_dismiss';
  const popupEl = document.getElementById('hf-popup-overlay') as HTMLElement;

  if (
    !popupEl ||
    sessionStorage.getItem('hf_popup_done') ||
    getCookie(SUPPRESS_COOKIE) ||
    getCookie(DISMISS_COOKIE)
  ) {
    // Suppressed — bail silently
  } else {
    const card    = document.getElementById('hf-popup-card') as HTMLElement;
    const closeBtn  = document.getElementById('hf-popup-close') as HTMLButtonElement;
    const form      = document.getElementById('popup-subscribe-form') as HTMLFormElement;
    const emailInp  = document.getElementById('popup-email-input') as HTMLInputElement;
    const msgEl     = document.getElementById('popup-form-message') as HTMLParagraphElement;
    const submitBtn = document.getElementById('popup-submit-btn') as HTMLButtonElement;
    const notNowBtn = document.getElementById('popup-not-now') as HTMLButtonElement;

    // ── Configuration ─────────────────────────────────────────────
    const TRIGGER_DELAY    = 20_000;      // 20s
    const SCROLL_THRESHOLD = 0.5;          // 50%

    let popupShown = false;

    // ── Helpers ──────────────────────────────────────────────────
    function sanitize(email: string): string {
    return email.trim().replace(/[^a-zA-Z0-9@._-]/g, '');
  }

  function validate(email: string): { valid: boolean; error?: string } {
    if (!email) return { valid: false, error: msgs.emailRequired };
    if (email.length > 254) return { valid: false, error: msgs.emailTooLong };
    const re = /^[a-zA-Z0-9][a-zA-Z0-9._-]*@[a-zA-Z0-9][a-zA-Z0-9.-]*\.[a-zA-Z]{2,}$/;
    if (!re.test(email)) return { valid: false, error: msgs.emailInvalid };
    return { valid: true };
  }

  function setMsg(text: string, type: string) {
    msgEl.textContent = text;
    msgEl.className = `popup-msg ${type}`;
  }

  function showPopup() {
    if (popupShown) return;
    popupShown = true;
    cleanupTriggers();
    popupEl.style.display = 'flex';
    popupEl.classList.remove('overlay-exit');
    void popupEl.offsetWidth;
    popupEl.classList.add('overlay-enter');
    card.classList.remove('popup-enter', 'popup-exit');
    void card.offsetWidth;
    card.classList.add('popup-enter');
  }

  function hidePopup(suppress = true) {
    card.classList.remove('popup-enter');
    card.classList.add('popup-exit');
    popupEl.classList.remove('overlay-enter');
    popupEl.classList.add('overlay-exit');
    const duration = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 0 : 280;
    setTimeout(() => {
      popupEl.style.display = 'none';
      card.classList.remove('popup-exit');
      popupEl.classList.remove('overlay-exit');
      if (suppress) {
        sessionStorage.setItem('hf_popup_done', '1');
        setCookie(DISMISS_COOKIE, '1', 1);  // 24h
      }
    }, duration);
  }

  function dismissForever() {
    sessionStorage.setItem('hf_popup_done', '1');
    setCookie(SUPPRESS_COOKIE, '1', 30);  // 30d
    setMsg(msgs.remindLater, 'info');
    setTimeout(() => hidePopup(false), 1500);
  }

  function cleanupTriggers() {
    clearTimeout(timer);
    document.removeEventListener('mouseleave', onMouseLeave);
    window.removeEventListener('scroll', onScroll);
  }

  // ── Timed trigger ────────────────────────────────────────────
  const timer = setTimeout(showPopup, TRIGGER_DELAY);

  // ── Scroll trigger (50%) with throttle ───────────────────────
  let scrollFired = false;
  function onScroll() {
    if (scrollFired) return;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    if (docHeight > 0 && window.scrollY / docHeight >= SCROLL_THRESHOLD) {
      scrollFired = true;
      showPopup();
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  // ── Exit intent with throttle ────────────────────────────────
  let lastLeave = 0;
  function onMouseLeave(e: MouseEvent) {
    const now = Date.now();
    if (now - lastLeave < 500) return;
    lastLeave = now;
    if (e.clientY < 10) showPopup();
  }
  document.addEventListener('mouseleave', onMouseLeave);

  // ── Escape key ───────────────────────────────────────────────
  function onKeyDown(e: KeyboardEvent) {
    if (e.key === 'Escape' && popupShown) hidePopup(true);
  }
  document.addEventListener('keydown', onKeyDown);

  // ── Close / dismiss ──────────────────────────────────────────
  if (closeBtn) closeBtn.addEventListener('click', () => hidePopup(true));
  if (notNowBtn) notNowBtn.addEventListener('click', () => hidePopup(true));
  if (popupEl) popupEl.addEventListener('click', (e) => {
    if (e.target === popupEl) hidePopup(true);
  });

  // ── Email validation ─────────────────────────────────────────
  if (emailInp && msgEl) {
    emailInp.addEventListener('input', () => {
      const val = emailInp.value;
      if (!val) { setMsg('', ''); return; }
      const result = validate(sanitize(val));
      result.valid
        ? setMsg(msgs.validEmail, 'success')
        : setMsg(result.error!, 'error');
    });
  }

  // ── Form submission ──────────────────────────────────────────
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = sanitize(emailInp.value);
      const check = validate(email);
      if (!check.valid) { setMsg(check.error!, 'error'); return; }

      submitBtn.classList.add('loading');
      submitBtn.disabled = true;
      setMsg(msgs.sending, 'info');

      try {
        const result = await subscribeEmail(email);

        if (result.success) {
          setMsg(msgs.success, 'success');
          emailInp.value = '';
          dismissForever();
          return;
        }
        if (result.message === 'Already subscribed.') {
          setMsg(msgs.alreadySubscribed, 'warning');
          dismissForever();
          return;
        }
        setMsg(result.message || msgs.error, 'error');
      } catch {
        setMsg(msgs.networkError, 'error');
      } finally {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
      }
    });
  }
  }
</script>

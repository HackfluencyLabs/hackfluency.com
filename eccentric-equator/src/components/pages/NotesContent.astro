---
import ResearchNav from '../ResearchNav.astro';
import { getTranslations } from '../../i18n/utils';
import type { Language } from '../../i18n/translations';

interface Props {
  locale?: Language;
}
const { locale = 'es' } = Astro.props;
const { t } = getTranslations(locale);
const base = import.meta.env.BASE_URL;

const notes = (locale === 'es' ? [
  {
    title: "Memoria Operacional Impulsada por Grafos",
    description: "Modelo conceptual para agentes de seguridad autónomos que utilizan embeddings de grafos evolutivos para mantener contexto operacional persistente entre sesiones. Explora cómo el conocimiento acumulado durante un engagement puede informar la toma de decisiones del agente en operaciones subsecuentes.",
    tags: ["Sistemas de IA", "Grafos de Conocimiento", "Operaciones Autónomas"],
    date: "Marzo 2026",
  },
  {
    title: "Bucle Adaptativo de Agente Red Team",
    description: "Diseño de bucle de ejecución auto-modificable para agentes ofensivos que ajusta tácticas basándose en la resistencia ambiental observada. El bucle trata las respuestas del defensor como señales que actualizan el modelo interno del agente sobre el entorno objetivo.",
    tags: ["Seguridad Ofensiva", "Diseño de Agentes", "Sistemas Autónomos"],
    date: "Marzo 2026",
  },
] : [
  {
    title: "Graph-Driven Operational Memory",
    description: "Conceptual model for autonomous security agents using evolving graph embeddings to maintain persistent operational context across sessions. Explores how knowledge accumulated during one engagement can inform agent decision-making in subsequent operations.",
    tags: ["AI Systems", "Knowledge Graphs", "Autonomous Operations"],
    date: "March 2026",
  },
  {
    title: "Adaptive Red Team Agent Loop",
    description: "Self-modifying execution loop design for offensive agents that adjusts tactics based on observed environmental resistance. The loop treats defender responses as signals that update the agent's internal model of the target environment.",
    tags: ["Offensive Security", "Agent Design", "Autonomous Systems"],
    date: "March 2026",
  },
]);
---

<ResearchNav activePage="notes" locale={locale} />

<main class="rpage">

  <!-- Section header -->
  <section class="rn-header">
    <div class="r-container">
      <span class="r-section-tag">{t('notes.tag')}</span>
      <h1 class="rn-title">{t('notes.title')}</h1>
      <p class="rn-description">
        {t('notes.desc1')}
      </p>
      <p class="rn-description">
        {t('notes.desc2')}
      </p>
      <div class="rn-meta-row">
        <span class="rn-count">{
          notes.length === 1
            ? t('notes.count').replace('{count}', String(notes.length))
            : t('notes.count.plural').replace('{count}', String(notes.length))
        }</span>
        <span class="rn-meta-sep">·</span>
        <span class="rn-meta-note">{t('notes.quickReads')}</span>
      </div>
    </div>
  </section>

  <!-- Notes grid -->
  <section class="rn-list">
    <div class="r-container">
      <div class="rn-grid">
        {notes.map((note) => (
          <article class="rn-card">
            <div class="rn-card-inner">
              <h2 class="rn-card-title">{note.title}</h2>
              <p class="rn-card-desc">{note.description}</p>
              <div class="rn-tags">
                {note.tags.map(tag => (
                  <span class="rn-tag">{tag}</span>
                ))}
              </div>
              <time class="rn-date">{note.date}</time>
            </div>
          </article>
        ))}
      </div>

      <!-- Evolution note -->
      <div class="rn-evolution">
        <div class="rn-evolution-flow" aria-label={t('notes.evolution.aria')}>
          <span class="rn-evo-step rn-evo-step--active">{t('notes.evolution.note')}</span>
          <span class="rn-evo-arrow" aria-hidden="true">→</span>
          <span class="rn-evo-step">
            <a href={locale === 'es' ? '/research/articles' : '/en/research/articles'} class="rn-evo-link">{t('notes.evolution.article')}</a>
          </span>
          <span class="rn-evo-arrow" aria-hidden="true">→</span>
          <span class="rn-evo-step">
            <a href={locale === 'es' ? '/research/tooling' : '/en/research/tooling'} class="rn-evo-link">{t('notes.evolution.tooling')}</a>
          </span>
        </div>
        <p class="rn-evolution-caption">
          {t('notes.evolution.caption')}
        </p>
      </div>

    </div>
  </section>

</main>

<!-- Footer -->
<footer class="r-footer">
  <div class="r-container">
    <div class="r-footer-inner">
        <a href={locale === 'es' ? '/research' : '/en/research'} class="r-footer-home">{t('notes.footer.back')}</a>
      <span class="r-footer-copy">{t('common.copyright')}</span>
      <a href="https://hackfluency.zohobookings.com/#/hackfluency" target="_blank" rel="noopener" class="r-footer-cta">
        {t('common.bookCall')}
      </a>
    </div>
  </div>
</footer>

<style>
  /* ── Layout ── */
  .rpage {
    min-height: 100vh;
    padding-top: 68px;
  }

  .r-container {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Section header ── */
  .rn-header {
    padding: 80px 0 52px;
    background: var(--hf-bg);
    border-bottom: 1px solid var(--hf-border);
  }

  .r-section-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hf-accent);
    margin-bottom: 16px;
  }

  .rn-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--hf-text);
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .rn-description {
    font-size: 1rem;
    color: var(--hf-text-muted);
    line-height: 1.75;
    max-width: 540px;
    margin-bottom: 10px;
  }

  .rn-description:last-of-type {
    margin-bottom: 28px;
  }

  .rn-meta-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .rn-count {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--hf-text-secondary);
  }

  .rn-meta-sep {
    color: var(--hf-text-dim);
    font-size: 0.82rem;
  }

  .rn-meta-note {
    font-size: 0.82rem;
    color: var(--hf-text-dim);
  }

  /* ── Notes list ── */
  .rn-list {
    padding: 56px 0 100px;
    background: var(--hf-bg);
  }

  .rn-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 20px;
    margin-bottom: 56px;
  }

  @media (max-width: 600px) {
    .rn-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Note card ── */
  .rn-card {
    background: var(--hf-bg-card);
    border: 1px solid var(--hf-border);
    border-radius: 14px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }

  .rn-card:hover {
    border-color: var(--hf-accent-border);
    box-shadow: 0 4px 20px var(--hf-accent-dim);
  }

  .rn-card::before {
    content: '';
    display: block;
    height: 3px;
    background: linear-gradient(90deg, var(--hf-accent), var(--hf-accent-light));
    opacity: 0.5;
  }

  .rn-card-inner {
    padding: 28px;
  }

  .rn-card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--hf-text);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .rn-card-desc {
    font-size: 0.875rem;
    color: var(--hf-text-muted);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .rn-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .rn-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--hf-accent);
    background: var(--hf-accent-dim);
    border: 1px solid var(--hf-accent-border);
    padding: 3px 9px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .rn-date {
    display: block;
    font-size: 0.78rem;
    color: var(--hf-text-dim);
    font-style: italic;
  }

  /* ── Evolution flow ── */
  .rn-evolution {
    padding: 24px 28px;
    background: var(--hf-bg-secondary);
    border: 1px solid var(--hf-border);
    border-radius: 12px;
  }

  .rn-evolution-flow {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .rn-evo-step {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--hf-text-dim);
  }

  .rn-evo-step--active {
    color: var(--hf-text-secondary);
    background: var(--hf-accent-dim);
    border: 1px solid var(--hf-accent-border);
    padding: 2px 10px;
    border-radius: 100px;
    color: var(--hf-accent);
  }

  .rn-evo-arrow {
    color: var(--hf-text-dim);
    font-size: 0.9rem;
  }

  .rn-evo-link {
    color: var(--hf-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .rn-evo-link:hover {
    color: var(--hf-accent);
  }

  .rn-evolution-caption {
    font-size: 0.82rem;
    color: var(--hf-text-dim);
    font-style: italic;
  }

  /* ── Footer ── */
  .r-footer {
    background: var(--hf-bg-secondary);
    border-top: 1px solid var(--hf-border);
    padding: 28px 0;
  }

  .r-footer-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .r-footer-home {
    font-size: 0.85rem;
    color: var(--hf-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .r-footer-home:hover {
    color: var(--hf-accent);
  }

  .r-footer-copy {
    font-size: 0.8rem;
    color: var(--hf-text-dim);
  }

  .r-footer-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--hf-accent);
    text-decoration: none;
    padding: 7px 16px;
    border: 1px solid var(--hf-accent-border);
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .r-footer-cta:hover {
    background: var(--hf-accent-dim);
  }
</style>

<Layout>
  <!-- Mobile Menu Toggle Script -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const menuBtn = document.querySelector('.mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const body = document.body;
      
      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const isOpen = mobileMenu.classList.toggle('active');
          menuBtn.classList.toggle('active');
          menuBtn.setAttribute('aria-expanded', isOpen.toString());
          menuBtn.setAttribute('aria-label', isOpen ? 'Close mobile menu' : 'Open mobile menu');
          body.style.overflow = isOpen ? 'hidden' : '';
        });
        
        // Close menu when clicking on a link
        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.remove('active');
            menuBtn.classList.remove('active');
            menuBtn.setAttribute('aria-expanded', 'false');
            menuBtn.setAttribute('aria-label', 'Open mobile menu');
            body.style.overflow = '';
          });
        });
        
        // Close menu when clicking outside
        mobileMenu.addEventListener('click', (e) => {
          if (e.target === mobileMenu) {
            mobileMenu.classList.remove('active');
            menuBtn.classList.remove('active');
            menuBtn.setAttribute('aria-expanded', 'false');
            menuBtn.setAttribute('aria-label', 'Open mobile menu');
            body.style.overflow = '';
          }
        });
      }
    });
  </script>

  <!-- Newsletter Subscription Script -->
  <script>
    import { subscribeEmail } from '../lib/subscription';

    // ===== CONFIGURATION =====
    const MAX_EMAIL_LENGTH = 254;
    const ALLOWED_EMAIL_CHARS = /^[a-zA-Z0-9@._-]+$/;

    // ===== DOM ELEMENTS =====
    const emailInput = document.getElementById("email-input") as HTMLInputElement | null;
    const message = document.getElementById("form-message") as HTMLElement | null;

    // ===== VALIDATION FUNCTIONS =====

    /**
     * Sanitizes email: trim and remove disallowed characters
     */
    function sanitizeEmail(email: string): string {
      email = email.trim();
      email = email.replace(/[^a-zA-Z0-9@._-]/g, '');
      return email;
    }

    /**
     * Validates email format with regex
     */
    function validateEmailFormat(email: string): boolean {
      const emailRegex = /^[a-zA-Z0-9][a-zA-Z0-9._-]*@[a-zA-Z0-9][a-zA-Z0-9.-]*\.[a-zA-Z]{2,}$/;
      return emailRegex.test(email);
    }

    /**
     * Validates email length (RFC 5321: 254 characters)
     */
    function validateEmailLength(email: string): boolean {
      return email.length <= MAX_EMAIL_LENGTH;
    }

    /**
     * Full email validation
     * Returns { valid: boolean, error?: string }
     */
    function validateEmail(email: string): { valid: boolean; error?: string } {
      if (!email) {
        return { valid: false, error: "Email is required" };
      }

      if (!validateEmailLength(email)) {
        return { valid: false, error: `Email exceeds ${MAX_EMAIL_LENGTH} characters` };
      }

      if (!ALLOWED_EMAIL_CHARS.test(email)) {
        return { valid: false, error: "Invalid characters. Only letters, numbers, @._- allowed" };
      }

      if (!validateEmailFormat(email)) {
        return { valid: false, error: "Invalid email format. Use user@domain.com" };
      }

      return { valid: true };
    }

    // ===== REAL-TIME VALIDATION =====
    if (emailInput && message) {
      emailInput.addEventListener("input", function(e) {
        const target = e.target as HTMLInputElement;
        const email = target.value;
        const validation = validateEmail(email);

        if (email.length === 0) {
          message.textContent = "";
          message.className = "form-message";
          return;
        }

        if (!validation.valid) {
          message.textContent = validation.error ?? "";
          message.className = "form-message error";
          return;
        }

        message.textContent = "Valid email";
        message.className = "form-message success";
      });

      // Clear message on blur if empty
      emailInput.addEventListener("blur", function(e) {
        const target = e.target as HTMLInputElement;
        const email = target.value;
        if (email.length === 0) {
          message.textContent = "";
          message.className = "form-message";
        }
      });

      // ===== FORM SUBMISSION =====
      const subscribeForm = document.getElementById("subscribe-form");
      subscribeForm?.addEventListener("submit", async function (e) {
          e.preventDefault();

          const email = sanitizeEmail(emailInput.value);
          const validation = validateEmail(email);

          // Pre-submit validation
          if (!validation.valid) {
            message.textContent = validation.error ?? "";
            message.className = "form-message error";
            return;
          }

          // Status: submitting
          message.className = "form-message info";
          message.textContent = "Subscribing...";

          try {
            const result = await subscribeEmail(email);

            if (result.success) {
              message.textContent = "Successfully subscribed!";
              emailInput.value = "";
              message.className = "form-message success";
              return;
            }
            if (result.message === 'Already subscribed.') {
              message.textContent = "Already subscribed.";
              message.className = "form-message warning";
              return;
            }
            message.textContent = result.message || "Error. Please try again.";
            message.className = "form-message error";

          } catch (error) {
            // Network error
            console.error(error);
            message.textContent = "Network error. Check connection.";
            message.className = "form-message error";
          }
        });
    }
  </script>


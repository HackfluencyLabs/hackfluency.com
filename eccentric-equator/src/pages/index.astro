    padding: 120px 0;
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 80px;
  }

  .section-tag {
    display: inline-block;
    padding: 6px 16px;
    background: var(--hf-accent-dim);
    border: 1px solid color-mix(in srgb, var(--hf-accent) 20%, transparent);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 20px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--gray-400);
    line-height: 1.7;
  }

  /* Services */
  .services {
    background: var(--dark);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    background: var(--gray-900);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 40px 32px;
    transition: all 0.4s ease;
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: var(--delay);
    animation-play-state: paused;
    opacity: 0;
  }

  .service-card.is-visible {
    animation-play-state: running;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .service-card:hover {
    transform: translateY(-8px);
    border-color: var(--hf-accent-border);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3), 0 0 30px var(--hf-accent-dim);
  }

  .service-card:hover .service-icon {
    color: var(--primary);
    filter: drop-shadow(0 0 12px var(--hf-accent-glow));
  }

  .service-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 24px;
    color: var(--gray-300);
    transition: color 0.3s ease, filter 0.3s ease;
  }

  .service-icon svg {
    width: 100%;
    height: 100%;
  }

  .service-title {
    font-size: 1.25rem;
    margin-bottom: 12px;
  }

  .service-description {
    color: var(--gray-400);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: 500;
    transition: gap 0.3s ease;
    padding: 12px 0;
    min-height: 44px;
  }

  .service-link:hover {
    gap: 12px;
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-text {
    color: var(--gray-400);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .about-features {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 32px;
  }

  .about-feature {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--gray-300);
  }

  .about-feature svg {
    color: var(--primary);
    flex-shrink: 0;
  }

  .about-visual {
    display: flex;
    justify-content: center;
  }

  .about-card {
    position: relative;
    width: 100%;
    max-width: 500px;
  }

  .about-card-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--hf-accent) 25%, transparent) 0%, transparent 70%);
    border-radius: 24px;
    filter: blur(40px);
    animation: pulseGlow 4s ease-in-out infinite alternate;
  }

  .about-card-content {
    position: relative;
    background: var(--gray-900);
    border: 1px solid var(--hf-border-subtle);
    border-radius: 16px;
    overflow: hidden;
  }

  .terminal-header {
    display: flex;
    gap: 8px;
    padding: 16px 20px;
    background: var(--gray-800);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-dot.red { background: var(--accent); }
  .terminal-dot.yellow { background: #f59e0b; }
  .terminal-dot.green { background: var(--primary); }

  .terminal-body {
    padding: 24px;
    font-family: 'Monaco', 'Consolas', monospace;
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .code-prompt { color: var(--primary); }
  .code-comment { color: var(--gray-600); }
  .code-success { color: var(--primary); }
  .cursor {
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Values */
  .values {
    background: var(--dark);
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .values-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .value-card {
    background: linear-gradient(180deg, var(--gray-900) 0%, rgba(31, 31, 31, 0.5) 100%);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 40px 32px;
    text-align: center;
    transition: all 0.4s ease;
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: var(--delay);
    animation-play-state: paused;
    opacity: 0;
  }

  .value-card.is-visible {
    animation-play-state: running;
  }

  .value-card:hover {
    transform: translateY(-8px);
    border-color: rgba(227, 27, 35, 0.5);
    box-shadow: 0 20px 60px rgba(227, 27, 35, 0.15), 0 0 30px var(--accent-glow);
  }

  .value-card:hover .value-icon {
    color: var(--accent);
    filter: drop-shadow(0 0 15px rgba(227, 27, 35, 0.6));
  }

  .value-icon {
    width: 56px;
    height: 56px;
    margin-bottom: 20px;
    color: var(--gray-300);
    transition: color 0.4s ease, filter 0.4s ease;
  }

  .value-icon svg {
    width: 100%;
    height: 100%;
  }

  .value-title {
    font-size: 1.25rem;
    margin-bottom: 12px;
    color: var(--white);
  }

  .value-description {
    color: var(--gray-400);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* CTA */
  .cta {
    position: relative;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
  }

  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 1200px;
    height: 700px;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--hf-accent) 20%, transparent) 0%, color-mix(in srgb, var(--hf-accent-light) 10%, transparent) 40%, transparent 60%);
    animation: pulseGlow 4s ease-in-out infinite alternate;
  }

  .cta-content {
    position: relative;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 20px;
  }

  .cta-subtitle {
    color: var(--gray-300);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .cta-features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    margin-bottom: 40px;
  }

  .cta-feature {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--primary);
    font-size: 0.95rem;
  }

  .cta-feature svg {
    flex-shrink: 0;
  }

  .cta-actions {
    margin-bottom: 24px;
  }

  .cta-note {
    color: var(--gray-500);
    font-size: 0.85rem;
  }

  /* Footer */
  .footer {
    background: var(--black);
    padding: 80px 0 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    margin-bottom: 60px;
  }

  @media (min-width: 768px) {
    .footer-content {
      grid-template-columns: 2fr 3fr;
    }
  }

  .footer-logo {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .footer-logo-img {
    width: 60px;
    height: 60px;
    filter: drop-shadow(0 0 15px var(--primary-glow));
  }

  .footer-tagline {
    color: var(--gray-500);
    margin-top: 16px;
    font-size: 0.95rem;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  @media (min-width: 640px) {
    .footer-links {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer-column h5 {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--white);
    margin-top: 0;
  }

  .footer-column a {
    display: block;
    color: var(--gray-500);
    font-size: 0.9rem;
    margin-bottom: 12px;
    padding: 8px 0;
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.3s ease;
  }

  .footer-column a:hover {
    color: var(--primary);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-bottom p {
    color: var(--gray-600);
    font-size: 0.875rem;
  }

  .footer-email {
    color: var(--gray-600);
    font-size: 0.8rem;
    transition: color 0.3s ease;
    opacity: 0.7;
  }

  .footer-email:hover {
    color: var(--gray-400);
    opacity: 1;
  }

  .footer-legal {
    display: flex;
    gap: 24px;
  }

  .footer-legal a {
    color: var(--gray-600);
    font-size: 0.875rem;
    transition: color 0.3s ease;
  }

  .footer-legal a:hover {
    color: var(--gray-400);
  }

  /* Newsletter Subscription */
  .newsletter-section {
    text-align: center;
    padding: 32px 24px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    margin-bottom: 48px;
  }

  .newsletter-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 8px;
  }

  .newsletter-subtitle {
    font-size: 0.9rem;
    color: var(--gray-400);
    margin-bottom: 20px;
  }

  .subscribe-form {
    display: flex;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }

  .subscribe-form input[type="email"] {
    flex: 1;
    min-width: 220px;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: var(--white);
    font-size: 0.95rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .subscribe-form input[type="email"]:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px var(--hf-accent-dim);
  }

  .subscribe-form input[type="email"]::placeholder {
    color: var(--gray-500);
  }

  .subscribe-btn {
    padding: 14px 28px;
    background: var(--gradient-primary);
    border: none;
    border-radius: 10px;
    color: var(--hf-text-on-accent);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .subscribe-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--primary-glow);
  }

  .subscribe-btn:active {
    transform: scale(0.98);
  }

  .form-message {
    width: 100%;
    font-size: 0.85rem;
    margin-top: 12px;
    min-height: 1.2em;
    text-align: center;
    transition: color 0.3s ease;
  }

  .form-message.success {
    color: var(--primary);
  }

  .form-message.error {
    color: #ff453a;
  }

  .form-message.warning {
    color: #ffd60a;
  }

  .form-message.info {
    color: var(--gray-400);
  }

  @media (max-width: 640px) {
    .subscribe-form {
      flex-direction: column;
    }

    .subscribe-form input[type="email"],
    .subscribe-btn {
      width: 100%;
    }
  }

  /* Trustpilot Widget Section */
  .trustpilot-section {
    padding: 40px 0;
    margin: 0;
    border-top: 1px solid var(--hf-border);
  }

  .trustpilot-inner {
    max-width: 520px;
    margin: 0 auto;
    background: linear-gradient(135deg, color-mix(in srgb, var(--hf-accent) 5%, transparent) 0%, transparent 80%);
    border: 1px solid var(--hf-accent-border);
    border-radius: 16px;
    padding: 28px 32px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .trustpilot-inner:hover {
    border-color: color-mix(in srgb, var(--hf-accent) 50%, transparent);
    box-shadow: 0 0 28px var(--hf-accent-dim);
  }

  .trustpilot-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .trustpilot-stars {
    display: flex;
    gap: 5px;
    margin-bottom: 2px;
  }

  .trustpilot-stars svg {
    width: 18px;
    height: 18px;
    fill: var(--hf-accent);
    filter: drop-shadow(0 0 4px var(--hf-accent-glow));
  }

  .trustpilot-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--hf-text);
    letter-spacing: 0.01em;
  }

  .trustpilot-sub {
    font-size: 0.78rem;
    color: var(--hf-text-muted);
    line-height: 1.5;
    max-width: 340px;
  }

  .trustpilot-widget {
    width: 100%;
  }

  .trustpilot-widget a {
    display: block;
    text-align: center;
    color: var(--hf-accent);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    padding: 12px 24px;
    border: 1px solid var(--hf-accent-border);
    border-radius: 10px;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }

  .trustpilot-widget a:hover {
    background: var(--hf-accent-dim);
    border-color: var(--hf-accent);
    color: var(--hf-accent-light);
  }
  
  /* Mobile Menu Overlay */
  .mobile-menu-overlay {
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    bottom: 0;
    background: color-mix(in srgb, var(--hf-bg) 97%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-top: 1px solid var(--hf-accent-border);
    box-shadow: inset 0 1px 0 0 var(--hf-border-subtle);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  
  .mobile-menu-overlay.active {
    opacity: 1;
    visibility: visible;
  }
  
  .mobile-menu-content {
    display: flex;
    flex-direction: column;
    padding: 16px;
    max-width: 480px;
    margin: 20px auto 0;
    background: color-mix(in srgb, var(--hf-bg-elevated) 96%, transparent);
    border-radius: 16px;
    border: 1px solid var(--hf-border);
    box-shadow: 0 8px 48px color-mix(in srgb, var(--hf-bg) 70%, transparent);
  }
  
  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 32px;
  }
  
  .mobile-nav-link {
    display: flex;
    align-items: center;
    padding: 16px 20px;
    background: var(--hf-bg-tertiary);
    border: 1px solid var(--hf-border);
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--hf-text);
    transition: all 0.3s ease;
    min-height: 56px;
  }
  
  .mobile-nav-link:hover {
    background: var(--hf-accent-dim);
    border-color: var(--hf-accent);
    color: var(--hf-accent);
    transform: translateX(8px);
  }

  .mobile-nav-link--research {
    color: var(--hf-accent);
    font-weight: 600;
    border-color: var(--hf-accent-border);
    background: var(--hf-accent-dim);
  }

  .mobile-nav-link--research:hover {
    background: var(--hf-accent-dim);
    border-color: var(--hf-accent);
  }
  
  .mobile-nav-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  /* Sign In button (pre-auth) */
  .mobile-nav-btn-signin {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 24px;
    background: var(--hf-bg-tertiary);
    border: 1px solid var(--hf-border-secondary);
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--hf-text);
    transition: all 0.3s ease;
    min-height: 56px;
    text-decoration: none;
  }
  .mobile-nav-btn-signin:hover {
    background: color-mix(in srgb, var(--hf-text) 8%, transparent);
    border-color: var(--hf-accent-border);
  }
  /* Dashboards button (post-auth) */
  .mobile-nav-btn-platform {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 24px;
    background: var(--hf-bg-tertiary);
    border: 1px solid var(--hf-border-secondary);
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--hf-text);
    transition: all 0.3s ease;
    min-height: 56px;
    text-decoration: none;
  }
  .mobile-nav-btn-platform:hover {
    background: color-mix(in srgb, var(--hf-text) 8%, transparent);
    border-color: var(--hf-accent-border);
  }
  /* Logout button (mobile) */
  .mobile-nav-btn-logout {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 16px 24px;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.35);
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    color: #dc2626;
    transition: all 0.3s ease;
    min-height: 56px;
    cursor: pointer;
    font-family: inherit;
  }
  .mobile-nav-btn-logout:hover {
    background: rgba(239, 68, 68, 0.18);
    border-color: rgba(239, 68, 68, 0.6);
  }
  /* On light themes the danger red needs deeper contrast */
  [data-theme-mode="light"] .mobile-nav-btn-logout {
    background: rgba(220, 38, 38, 0.08);
    border-color: rgba(220, 38, 38, 0.4);
    color: #b91c1c;
  }
  [data-theme-mode="light"] .mobile-nav-btn-logout:hover {
    background: rgba(220, 38, 38, 0.15);
    border-color: rgba(220, 38, 38, 0.65);
  }
  /* Kept for any legacy refs */
  .mobile-nav-btn-dashboard {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 24px;
    background: var(--hf-bg-tertiary);
    border: 1px solid var(--hf-border-secondary);
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--hf-text);
    transition: all 0.3s ease;
    min-height: 56px;
    text-decoration: none;
  }
  
  .mobile-nav-btn-threat {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 24px;
    background: linear-gradient(135deg, #0099FF 0%, #00B4D8 100%);
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--hf-text);
    transition: all 0.3s ease;
    min-height: 56px;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 153, 255, 0.3);
  }
  
  .mobile-nav-btn-threat:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 153, 255, 0.5);
    background: linear-gradient(135deg, #00B4D8 0%, #0099FF 100%);
  }
  
  .mobile-nav-btn-dashboard:hover {
    background: color-mix(in srgb, var(--hf-text) 8%, transparent);
    border-color: var(--hf-accent-border);
  }
  /* Desktop logout button */
  .nav-btn-logout {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #dc2626;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s ease;
    white-space: nowrap;

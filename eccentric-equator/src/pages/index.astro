<!-- Trustpilot: reinitialize widget after Astro View Transitions navigation -->
<script>
  declare global {
    interface Window {
      Trustpilot?: { loadFromElement: (el: Element, force?: boolean) => void };
    }
  }

  document.addEventListener('astro:page-load', () => {
    const widget = document.querySelector('.trustpilot-widget');
    if (!widget) return;

    if (window.Trustpilot) {
      // Widget already initialized before — force a reload
      window.Trustpilot.loadFromElement(widget, true);
    } else {
      // Script not yet ready; wait for it then load
      const script = document.querySelector<HTMLScriptElement>(
        'script[src*="tp.widget.bootstrap"]'
      );
      if (script) {
        script.addEventListener('load', () => {
          window.Trustpilot?.loadFromElement(widget, true);
        }, { once: true });
      }
    }
  });
</script>

<!-- Scroll animations: count-up stats + viewport-triggered card entrances -->
<script>
  document.addEventListener('astro:page-load', () => {
    // Reset card visibility state on every page load (needed for View Transitions back-nav)
    document.querySelectorAll<HTMLElement>('.service-card, .value-card').forEach(el => {
      el.classList.remove('is-visible');
    });

    // Skip all scroll animations if user prefers reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll<HTMLElement>('.service-card, .value-card').forEach(el => {
        el.style.opacity = '1';
        el.style.animation = 'none';
      });
      return;
    }

    // ── Card entrance animations ──────────────────────────────────
    const cardObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.querySelectorAll<HTMLElement>('.service-card, .value-card').forEach(card => {
              card.classList.add('is-visible');
            });
            cardObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll('.services-grid, .values-grid').forEach(grid => {
      cardObserver.observe(grid);
    });

    // ── Stat count-up animation ───────────────────────────────────
    function animateCount(el: HTMLElement, target: string) {
      const numericPart = parseFloat(target.replace(/[^0-9.]/g, ''));
      const suffix = target.replace(/[0-9.]/g, '');
      if (isNaN(numericPart) || target.includes('/')) return; // e.g. "24/7" — skip
      const duration = 1500;
      const startTime = performance.now();
      const startValue = 0;

      const step = (currentTime: number) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        // Ease-out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = startValue + (numericPart - startValue) * eased;
        // Format: if original had decimal, keep 1dp, else integer
        const formatted = target.includes('.') ? current.toFixed(1) : Math.round(current).toString();
        el.textContent = formatted + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }

    const statsObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.querySelectorAll<HTMLElement>('.stat-value[data-count]').forEach(el => {
              const target = el.dataset.count || el.textContent || '';
              animateCount(el, target);
            });
            statsObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.4 }
    );

    const heroStats = document.querySelector('.hero-stats');
    if (heroStats) statsObserver.observe(heroStats);
  });
</script>

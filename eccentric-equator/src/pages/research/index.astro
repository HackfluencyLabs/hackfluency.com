---
import Layout from '../../layouts/Layout.astro';
import ResearchNav from '../../components/ResearchNav.astro';
---

<Layout
  title="Research & Innovation | Hackfluency"
  description="Hackfluency publishes technical research exploring cybersecurity, AI-driven operations and complex system architectures. Architectural thinking, experimental systems and proprietary security tooling."
>
  <ResearchNav />

  <main class="rpage">

    <!-- Hero -->
    <section class="r-hero">
      <div class="r-container">
        <div class="r-badge">
          <span class="r-badge-dot"></span>
          Technical Research · Open Knowledge
        </div>
        <h1 class="r-hero-title">Research &amp; Innovation</h1>
        <div class="r-hero-description">
          <p>
            Hackfluency publishes technical research exploring cybersecurity,
            AI-driven operations and complex system architectures.
          </p>
          <p>
            Our work spans architectural thinking, experimental systems and
            proprietary security tooling.
          </p>
        </div>
        <div class="r-hero-actions">
          <a href="/research/articles" class="r-btn r-btn--primary">View Articles</a>
          <a href="/research/notes" class="r-btn r-btn--secondary">Architecture Notes</a>
          <a href="/research/tooling" class="r-btn r-btn--secondary">Explore Tooling</a>
        </div>
      </div>
    </section>

    <!-- Knowledge flow diagram -->
    <section class="r-flow">
      <div class="r-container">
        <div class="r-flow-diagram" aria-label="Knowledge production flow: Architecture Note evolves into Research Article, which evolves into Tooling Implementation">
          <div class="r-flow-step">
            <div class="r-flow-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 20h9"/>
                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
            </div>
            <span class="r-flow-label">Architecture Note</span>
          </div>
          <div class="r-flow-arrow" aria-hidden="true">→</div>
          <div class="r-flow-step">
            <div class="r-flow-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </div>
            <span class="r-flow-label">Research Article</span>
          </div>
          <div class="r-flow-arrow" aria-hidden="true">→</div>
          <div class="r-flow-step">
            <div class="r-flow-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
            </div>
            <span class="r-flow-label">Tooling Implementation</span>
          </div>
        </div>
        <p class="r-flow-caption">Ideas evolve. Notes become articles. Articles become tools.</p>
      </div>
    </section>

    <!-- Section preview cards -->
    <section class="r-sections">
      <div class="r-container">
        <div class="r-sections-grid">

          <!-- Articles -->
          <a href="/research/articles" class="r-section-card">
            <div class="r-section-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </div>
            <div class="r-section-body">
              <h2 class="r-section-title">Articles</h2>
              <p class="r-section-desc">
                Full-depth technical research — security architecture, AI-driven systems,
                and applied operational design. Developed with implementation detail.
              </p>
            </div>
            <span class="r-section-arrow" aria-hidden="true">→</span>
          </a>

          <!-- Architecture Notes -->
          <a href="/research/notes" class="r-section-card">
            <div class="r-section-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 20h9"/>
                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
            </div>
            <div class="r-section-body">
              <h2 class="r-section-title">Architecture Notes</h2>
              <p class="r-section-desc">
                Short conceptual explorations — ideas, architectural patterns and emerging
                concepts that later evolve into full research or tooling.
              </p>
            </div>
            <span class="r-section-arrow" aria-hidden="true">→</span>
          </a>

          <!-- Tooling -->
          <a href="/research/tooling" class="r-section-card">
            <div class="r-section-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
            </div>
            <div class="r-section-body">
              <h2 class="r-section-title">Tooling</h2>
              <p class="r-section-desc">
                Proprietary security systems and experimental platforms built at Hackfluency —
                tools that power our consulting and advance the field.
              </p>
            </div>
            <span class="r-section-arrow" aria-hidden="true">→</span>
          </a>

        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="r-footer">
    <div class="r-container">
      <div class="r-footer-inner">
        <a href="/" class="r-footer-home">← hackfluency.com</a>
        <span class="r-footer-copy">© 2026 Hackfluency. All rights reserved.</span>
        <a href="https://hackfluency.zohobookings.com/#/hackfluency" target="_blank" rel="noopener" class="r-footer-cta">
          Book a Call
        </a>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ── Layout ── */
  .rpage {
    min-height: 100vh;
    padding-top: 68px;
  }

  .r-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Hero ── */
  .r-hero {
    padding: 100px 0 72px;
    background: var(--hf-bg);
  }

  .r-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border: 1px solid var(--hf-accent-border);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--hf-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .r-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--hf-accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .r-hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--hf-text);
    line-height: 1.1;
    margin-bottom: 28px;
    max-width: 680px;
  }

  .r-hero-description {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 580px;
    margin-bottom: 44px;
  }

  .r-hero-description p {
    font-size: 1.05rem;
    color: var(--hf-text-muted);
    line-height: 1.75;
  }

  .r-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .r-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 26px;
    border-radius: 10px;
    font-size: 0.925rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    min-height: 44px;
    white-space: nowrap;
  }

  .r-btn--primary {
    background: var(--hf-accent);
    color: var(--hf-text-on-accent);
    box-shadow: 0 4px 16px var(--hf-accent-dim);
  }

  .r-btn--primary:hover {
    background: var(--hf-accent-light);
    transform: translateY(-1px);
    box-shadow: 0 6px 24px var(--hf-accent-border);
  }

  .r-btn--secondary {
    background: transparent;
    color: var(--hf-text);
    border: 1px solid var(--hf-border);
  }

  .r-btn--secondary:hover {
    border-color: var(--hf-accent-border);
    background: var(--hf-accent-dim);
    color: var(--hf-accent);
  }

  /* ── Knowledge flow diagram ── */
  .r-flow {
    padding: 0 0 64px;
    background: var(--hf-bg);
  }

  .r-flow-diagram {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    padding: 28px 32px;
    background: var(--hf-bg-card);
    border: 1px solid var(--hf-border);
    border-radius: 16px;
    margin-bottom: 16px;
  }

  .r-flow-step {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .r-flow-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--hf-accent-border);
    border-radius: 8px;
    background: var(--hf-accent-dim);
    flex-shrink: 0;
  }

  .r-flow-icon svg {
    width: 18px;
    height: 18px;
    stroke: var(--hf-accent);
  }

  .r-flow-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--hf-text-secondary);
    white-space: nowrap;
  }

  .r-flow-arrow {
    font-size: 1.1rem;
    color: var(--hf-text-dim);
    font-weight: 300;
  }

  .r-flow-caption {
    font-size: 0.82rem;
    color: var(--hf-text-dim);
    font-style: italic;
  }

  /* ── Section preview cards ── */
  .r-sections {
    padding: 0 0 100px;
    background: var(--hf-bg);
  }

  .r-sections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .r-section-card {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 28px 24px;
    background: var(--hf-bg-card);
    border: 1px solid var(--hf-border);
    border-radius: 16px;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
  }

  .r-section-card:hover {
    border-color: var(--hf-accent-border);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px var(--hf-accent-dim);
  }

  .r-section-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--hf-accent-border);
    border-radius: 12px;
    background: var(--hf-accent-dim);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .r-section-icon svg {
    width: 22px;
    height: 22px;
    stroke: var(--hf-accent);
  }

  .r-section-body {
    flex: 1;
  }

  .r-section-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--hf-text);
    margin-bottom: 8px;
  }

  .r-section-desc {
    font-size: 0.875rem;
    color: var(--hf-text-muted);
    line-height: 1.65;
  }

  .r-section-arrow {
    font-size: 1.25rem;
    color: var(--hf-text-dim);
    flex-shrink: 0;
    align-self: center;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .r-section-card:hover .r-section-arrow {
    color: var(--hf-accent);
    transform: translateX(3px);
  }

  /* ── Footer ── */
  .r-footer {
    background: var(--hf-bg-secondary);
    border-top: 1px solid var(--hf-border);
    padding: 28px 0;
  }

  .r-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .r-footer-home {
    font-size: 0.85rem;
    color: var(--hf-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .r-footer-home:hover {
    color: var(--hf-accent);
  }

  .r-footer-copy {
    font-size: 0.8rem;
    color: var(--hf-text-dim);
  }

  .r-footer-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--hf-accent);
    text-decoration: none;
    padding: 7px 16px;
    border: 1px solid var(--hf-accent-border);
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .r-footer-cta:hover {
    background: var(--hf-accent-dim);
  }
</style>
